# Copyright (c) 2025-2026 Kaptain contributors (Fred Cooke)
#
# convert-tokens-in-tree - Rewrites unresolved tokens in a directory of files
# from one (delimiter, name) scheme to another, in place.
#
# Reads every file under <directory>, scans for tokens in the (from-delim,
# from-name) scheme, and rewrites each occurrence in the equivalent
# (to-delim, to-name) form. Operates only on tokens that are present;
# files with no matches are untouched. If the source and target schemes
# are identical, the script is a no-op.
#
# Intended for the product/environment build path where bundles arriving
# in a different but auto-convertible scheme need to be normalised to the
# product or environment's chosen scheme before merging. Operates on a
# single bundle's tree at a time, never on a merged staging tree.
#
# Usage:
#   convert-tokens-in-tree <from-delim> <from-name> <to-delim> <to-name> <directory>
#
# Arguments:
#   from-delim   - Source delimiter style (shell, mustache, helm, etc.)
#   from-name    - Source name style (PascalCase, UPPER_SNAKE, etc.)
#   to-delim     - Target delimiter style
#   to-name      - Target name style
#   directory    - Directory of files to rewrite in place
#   base-indent  - Optional. Prefix prepended to every log line so callers
#                  can nest this script's output under their own headers.
#                  Defaults to empty.
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/lib/token-format.bash
source "${SCRIPT_DIR}/../lib/token-format.bash"
# shellcheck source=src/scripts/defaults/output-sub-path.bash
source "${SCRIPT_DIR}/../defaults/output-sub-path.bash"

if [[ $# -lt 5 || $# -gt 6 ]]; then
  log_error "Usage: convert-tokens-in-tree <from-delim> <from-name> <to-delim> <to-name> <directory> [base-indent]"
  exit 1
fi

FROM_DELIM="${1}"
FROM_NAME="${2}"
TO_DELIM="${3}"
TO_NAME="${4}"
TARGET_DIR="${5}"
BASE_INDENT="${6:-}"

# Validate styles
if ! is_valid_substitution_token_style "${FROM_DELIM}"; then
  log_error "Unknown from-delim style: ${FROM_DELIM}"
  exit 2
fi
if ! is_valid_token_name_style "${FROM_NAME}"; then
  log_error "Unknown from-name style: ${FROM_NAME}"
  exit 2
fi
if ! is_valid_substitution_token_style "${TO_DELIM}"; then
  log_error "Unknown to-delim style: ${TO_DELIM}"
  exit 2
fi
if ! is_valid_token_name_style "${TO_NAME}"; then
  log_error "Unknown to-name style: ${TO_NAME}"
  exit 2
fi

# Kaptain convention is context-root-relative paths throughout, and the
# audit-trail slot name embeds this path - reject anything else so the
# slug stays short, portable, and deterministic across checkouts.
if [[ "${TARGET_DIR}" == /* ]]; then
  log_error "Target directory must be relative to the build context root, got absolute path: ${TARGET_DIR}"
  exit 2
fi
if [[ "${TARGET_DIR}" == ".." || "${TARGET_DIR}" == "../"* || "${TARGET_DIR}" == *"/../"* || "${TARGET_DIR}" == *"/.." ]]; then
  log_error "Target directory must not contain '..' segments: ${TARGET_DIR}"
  exit 2
fi

if [[ ! -d "${TARGET_DIR}" ]]; then
  log_error "Directory not found: ${TARGET_DIR}"
  exit 1
fi

# Same-scheme: nothing to do
if [[ "${FROM_DELIM}" == "${TO_DELIM}" && "${FROM_NAME}" == "${TO_NAME}" ]]; then
  log "${BASE_INDENT}No conversion needed (from and to schemes are identical: ${FROM_DELIM}-${FROM_NAME})"
  exit 0
fi

# Collect unique unresolved token names in the source scheme
TOKEN_NAMES=$("${SCRIPT_DIR}/scan-unresolved-tokens" "${FROM_DELIM}" "${FROM_NAME}" "${TARGET_DIR}")

if [[ -z "${TOKEN_NAMES}" ]]; then
  log "${BASE_INDENT}No ${FROM_DELIM}-${FROM_NAME} tokens found in ${TARGET_DIR}"
  exit 0
fi

# Build TSV mapping: from-ref<TAB>to-ref, one per line. The mapping file
# (and a record of the conversion) is preserved under OUTPUT_SUB_PATH as
# audit trail; the slug is the target dir as given (with '/' and ':'
# turned into '_'), and N walks 0,1,2,... until a free slot is found.
slug=$(echo "${TARGET_DIR}" | tr '/:' '__')
# Belt and braces: relative targets keep this short by construction, but a
# pathological tree could still approach NAME_MAX - fail legibly, not in mkdir.
if [[ ${#slug} -gt 200 ]]; then
  log_error "Audit slug for target directory exceeds 200 characters (${#slug}); shorten the target path: ${TARGET_DIR}"
  exit 2
fi
mapping_base="${OUTPUT_SUB_PATH}/convert-tokens-in-tree/token-mappings"
mkdir -p "${mapping_base}"
n=0
while [[ -e "${mapping_base}/${slug}-${n}" ]]; do
  n=$((n + 1))
done
MAPPING_DIR="${mapping_base}/${slug}-${n}"
mkdir -p "${MAPPING_DIR}"
echo "${TARGET_DIR}" > "${MAPPING_DIR}/target-dir"
echo "${FROM_DELIM}-${FROM_NAME}" > "${MAPPING_DIR}/from-scheme"
echo "${TO_DELIM}-${TO_NAME}" > "${MAPPING_DIR}/to-scheme"
MAPPING_FILE="${MAPPING_DIR}/mapping.tsv"
: > "${MAPPING_FILE}"
REPLACEMENTS_BY_FILE="${MAPPING_DIR}/replacements-by-file.tsv"
: > "${REPLACEMENTS_BY_FILE}"

while IFS= read -r from_name_raw; do
  [[ -z "${from_name_raw}" ]] && continue
  canonical=$(canonicalize_token_name "${FROM_NAME}" "${from_name_raw}")
  from_ref=$(format_canonical_token "${FROM_DELIM}" "${FROM_NAME}" "${canonical}")
  to_ref=$(format_canonical_token "${TO_DELIM}" "${TO_NAME}" "${canonical}")
  printf '%s\t%s\n' "${from_ref}" "${to_ref}" >> "${MAPPING_FILE}"
done <<< "${TOKEN_NAMES}"

if [[ ! -s "${MAPPING_FILE}" ]]; then
  log "${BASE_INDENT}No tokens to convert in ${TARGET_DIR}"
  exit 0
fi

mapping_count=$(wc -l < "${MAPPING_FILE}" | tr -d ' ')
unique_plural="tokens"
[[ "${mapping_count}" -eq 1 ]] && unique_plural="token"
log "${BASE_INDENT}Converting from ${FROM_DELIM}-${FROM_NAME} to ${TO_DELIM}-${TO_NAME}"
log "${BASE_INDENT}Converting ${mapping_count} unique ${unique_plural} in ${TARGET_DIR}"

# Apply mappings to every regular file under the directory.
# awk does literal substring substitution via index() so delimiter chars
# never need escaping. Output goes to a sibling .converting temp file then
# mv into place. The input's trailing-newline state is preserved.
total_replacements=0
while IFS= read -r -d '' file; do
  tmp="${file}.converting"
  stats="${file}.convert-stats"

  awk -v map_path="${MAPPING_FILE}" -v stats="${stats}" '
    BEGIN {
      n = 0
      while ((getline line < map_path) > 0) {
        tab = index(line, "\t")
        if (tab > 0) {
          n++
          from[n] = substr(line, 1, tab - 1)
          to[n]   = substr(line, tab + 1)
        }
      }
      close(map_path)
      replacements = 0
    }
    {
      line = $0
      for (i = 1; i <= n; i++) {
        result = ""
        from_str = from[i]
        from_len = length(from_str)
        if (from_len == 0) continue
        rest = line
        while ((idx = index(rest, from_str)) > 0) {
          result = result substr(rest, 1, idx - 1) to[i]
          rest = substr(rest, idx + from_len)
          replacements++
        }
        line = result rest
      }
      print line
    }
    END {
      print replacements > stats
      close(stats)
    }
  ' "${file}" > "${tmp}"

  file_replacements=$(cat "${stats}" 2>/dev/null || echo 0)
  rm -f "${stats}"
  : "${file_replacements:=0}"

  if [[ "${file_replacements}" -gt 0 ]]; then
    # Preserve the input file's trailing-newline state. awk's `print`
    # always appends one; if the input did not end with a newline,
    # strip the trailing one from the temp file before mv.
    if [[ -s "${file}" && -n "$(tail -c1 "${file}")" ]]; then
      # Input had no trailing newline (last byte is non-newline).
      content=$(cat "${tmp}" && printf 'x')
      content="${content%x}"
      content="${content%$'\n'}"
      printf '%s' "${content}" > "${tmp}"
    fi
    mv "${tmp}" "${file}"
    total_replacements=$((total_replacements + file_replacements))
    relative="${file#"${TARGET_DIR}"/}"
    printf '%s\t%s\n' "${relative}" "${file_replacements}" >> "${REPLACEMENTS_BY_FILE}"
    plural="instances"
    [[ "${file_replacements}" -eq 1 ]] && plural="instance"
    log "${BASE_INDENT} - Converted ${file_replacements} token ${plural} in ${relative}"
  else
    rm -f "${tmp}"
  fi
done < <(find "${TARGET_DIR}" -type f -print0)

log "${BASE_INDENT}Total replacements: ${total_replacements}"
