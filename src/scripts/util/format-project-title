#
# Formats a kebab-case project name into a display title with proper casing.
# Usage: format-project-title <project-name>
# Output: Formatted title to stdout
#
# Example: format-project-title "buildon-github-actions" -> "Buildon GitHub Actions"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"

if [[ $# -ne 1 ]]; then
  log_error "Usage: format-project-title <project-name>"
  exit 1
fi

project_name="$1"

# Map special words to their display form (bash 3.2 compatible)
map_word() {
  case "$1" in
    api) echo "API" ;;
    ubi) echo "UBI" ;;
    json) echo "JSON" ;;
    yaml) echo "YAML" ;;
    xml) echo "XML" ;;
    csv) echo "CSV" ;;
    sql) echo "SQL" ;;
    github) echo "GitHub" ;;
    devops) echo "DevOps" ;;
    cli) echo "CLI" ;;
    sdk) echo "SDK" ;;
    http) echo "HTTP" ;;
    https) echo "HTTPS" ;;
    url) echo "URL" ;;
    ip) echo "IP" ;;
    dns) echo "DNS" ;;
    ssl) echo "SSL" ;;
    tls) echo "TLS" ;;
    ssh) echo "SSH" ;;
    tcp) echo "TCP" ;;
    udp) echo "UDP" ;;
    jwt) echo "JWT" ;;
    id) echo "ID" ;;
    ui) echo "UI" ;;
    io) echo "IO" ;;
    ci) echo "CI" ;;
    cd) echo "CD" ;;
    vm) echo "VM" ;;
    cpu) echo "CPU" ;;
    gpu) echo "GPU" ;;
    lts) echo "LTS" ;;
    oci) echo "OCI" ;;
    iam) echo "IAM" ;;
    vpc) echo "VPC" ;;
    aws) echo "AWS" ;;
    gcp) echo "GCP" ;;
    eks) echo "EKS" ;;
    aks) echo "AKS" ;;
    gke) echo "GKE" ;;
    ec2) echo "EC2" ;;
    ecr) echo "ECR" ;;
    ecs) echo "ECS" ;;
    rds) echo "RDS" ;;
    s3) echo "S3" ;;
    sre) echo "SRE" ;;
    k8s) echo "K8s" ;;
    *) echo "" ;;
  esac
}

result=""
for word in ${project_name//-/ }; do
  # Convert to lowercase for lookup
  lower=$(echo "${word}" | tr '[:upper:]' '[:lower:]')
  mapped=$(map_word "${lower}")
  if [[ -n "${mapped}" ]]; then
    result+="${mapped} "
  else
    # Title case: uppercase first letter
    first=$(echo "${word:0:1}" | tr '[:lower:]' '[:upper:]')
    rest=$(echo "${word:1}" | tr '[:upper:]' '[:lower:]')
    result+="${first}${rest} "
  fi
done

# Remove trailing space
echo "${result% }"
