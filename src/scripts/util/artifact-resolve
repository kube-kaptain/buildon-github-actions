#
# artifact-resolve - Resolve artifact references via provider plugins
#
# Thin router: strips the provider prefix (if present), defaults to
# ARTIFACT_RESOLUTION_PROVIDER, and dispatches to the matching plugin.
#
# Usage: artifact-resolve <reference> <output-file>
#   reference:   [provider|]identifier:version
#   output-file: path to write the resolved URI to
#
# Examples:
#   artifact-resolve "quality-strict:1.0" kaptainpm/resolve/quality-strict
#   artifact-resolve "docker|java/java-web:2.1" kaptain-out/artifact-resolve/java-web
#
# Env:
#   ARTIFACT_RESOLUTION_PROVIDER - default provider (default: docker)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGINS_DIR="${SCRIPT_DIR}/../plugins/artifact-providers"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/defaults/artifact-resolution.bash
source "${SCRIPT_DIR}/../defaults/artifact-resolution.bash"

reference="${1:?Usage: artifact-resolve <reference> <output-file>}"
output_file="${2:?Usage: artifact-resolve <reference> <output-file>}"

# Split on | to extract provider prefix
if [[ "${reference}" == *"|"* ]]; then
  provider="${reference%%|*}"
  remainder="${reference#*|}"
else
  provider="${ARTIFACT_RESOLUTION_PROVIDER}"
  remainder="${reference}"
fi

if [[ -z "${provider}" ]]; then
  log_error "Empty provider in reference: ${reference}"
  exit 1
fi

plugin="${PLUGINS_DIR}/${provider}"
if [[ ! -x "${plugin}" ]]; then
  log_error "Unknown artifact provider: ${provider} (no plugin at ${plugin})"
  exit 1
fi

exec "${plugin}" "${remainder}" "${output_file}"
