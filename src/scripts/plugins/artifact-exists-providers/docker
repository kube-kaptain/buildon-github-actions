# artifact-exists-providers/docker - Docker/OCI artifact existence provider
#
# Verifies that an OCI image reference exists at the remote registry without
# pulling any layers/blobs. Uses `docker manifest inspect` (or podman
# equivalent) for a lightweight HEAD-style check.
#
# Accepts short, prefixed, or full reference forms - expansion is shared with
# the resolve provider so both plugins treat refs identically.
#
# Usage: docker <reference>
#   reference: name:version, prefix/name:version, or registry/namespace/prefix/name:version
#
# Exit:
#   0 - artifact exists at the remote
#   1 - artifact does not exist (or cannot be confirmed)
#
# Env:
#   IMAGE_BUILD_COMMAND      - podman or docker (required)
#   DOCKER_TARGET_REGISTRY   - required for short/prefixed form expansion
#   DOCKER_TARGET_NAMESPACE  - required for short/prefixed form expansion
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../../lib/log.bash"
# shellcheck source=src/scripts/lib/docker-ref-expand.bash
source "${SCRIPT_DIR}/../../lib/docker-ref-expand.bash"

reference="${1:?Usage: docker <reference>}"

if [[ -z "${IMAGE_BUILD_COMMAND:-}" ]]; then
  log_error "IMAGE_BUILD_COMMAND is required for remote existence check"
  exit 1
fi

# Expand the reference - handles short/prefixed/full the same way the resolve
# plugin does, so a short-form ref (stored in KaptainPM.yaml) becomes the fully
# qualified URI before we hand it to `manifest inspect`.
docker_ref_expand "${reference}" || exit 1
full_ref="${DOCKER_REF_FULL_NAME}:${DOCKER_REF_VERSION_PART}"

# PRERELEASE versions are local-only by convention - never published to the
# remote. In local mode, check the local image store instead of the remote.
# In server mode the provider keeps its remote-only contract; callers that
# need to reject PRERELEASE deps outright gate on it before calling here
# (see layer-package-prepare).
if [[ "${BUILD_MODE:-}" == "local" && "${DOCKER_REF_VERSION_PART}" == *-PRERELEASE* ]]; then
  log "Checking local existence of ${full_ref} (PRERELEASE version in BUILD_MODE=local, skipping remote)..."
  if "${IMAGE_BUILD_COMMAND}" image exists "${full_ref}" 2>/dev/null; then
    log "Exists locally: ${full_ref}"
    exit 0
  fi
  log_error "PRERELEASE version not available in local image store: ${full_ref}"
  exit 1
fi

log "Checking remote existence of ${full_ref} via ${IMAGE_BUILD_COMMAND} manifest inspect..."
if "${IMAGE_BUILD_COMMAND}" manifest inspect "${full_ref}" >/dev/null 2>&1; then
  log "Exists: ${full_ref}"
  exit 0
fi

log_error "Does not exist at remote: ${full_ref}"
exit 1
