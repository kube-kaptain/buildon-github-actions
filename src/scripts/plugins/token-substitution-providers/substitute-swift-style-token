#
# substitute-swift-style-token - Substitutes \(TOKEN) in a content buffer
#
# Sourced by substitute-tokens-from-dir. Defines substitute_swift_style_token()
# which mutates a caller-supplied string buffer in place (no file I/O).
#
# Note: the backslash is part of the literal pattern in the file, not an
# escape sequence. The pattern in files looks like: \(MyVar)

# shellcheck shell=bash
# shellcheck disable=SC2034  # SUBSTITUTE_TOKEN_COUNT consumed by sourcing router

substitute_swift_style_token() {
  local token_name="${1}"
  local token_value="${2}"
  local content_var="${3}"

  local subst_buf="${!content_var}"
  local subst_pattern="\\(${token_name})"

  if [[ "${subst_buf}" != *"${subst_pattern}"* ]]; then
    SUBSTITUTE_TOKEN_COUNT=0
    return 0
  fi

  local subst_count=0
  local subst_result=""
  local subst_remainder="${subst_buf}"
  while [[ "${subst_remainder}" == *"${subst_pattern}"* ]]; do
    # In glob patterns, backslash escapes the next character.
    # We need to match a literal backslash followed by (token_name).
    # shellcheck disable=SC2295 # token_name is validated (no glob chars)
    local subst_prefix="${subst_remainder%%\\(${token_name})*}"
    # shellcheck disable=SC2295 # token_name is validated (no glob chars)
    local subst_suffix="${subst_remainder#*\\(${token_name})}"
    subst_result="${subst_result}${subst_prefix}${token_value}"
    subst_remainder="${subst_suffix}"
    subst_count=$((subst_count + 1))
  done
  subst_result="${subst_result}${subst_remainder}"

  printf -v "${content_var}" '%s' "${subst_result}"
  SUBSTITUTE_TOKEN_COUNT="${subst_count}"
}
