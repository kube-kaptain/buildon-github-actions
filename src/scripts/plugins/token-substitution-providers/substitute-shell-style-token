#
# substitute-shell-style-token - Substitutes shell-style ${TOKEN} in a content buffer
#
# Sourced by substitute-tokens-from-dir. Defines substitute_shell_style_token()
# which mutates a caller-supplied string buffer in place. No file I/O; the
# router reads each target file once per pass, calls all providers against
# the in-memory content, then writes once.
#
# Function:
#   substitute_shell_style_token <token-name> <token-value> <content-var-name>
#     Reads content from the named variable (indirect expansion),
#     replaces ${<token-name>} with <token-value>, writes the result back
#     into the same named variable (printf -v).
#     Sets SUBSTITUTE_TOKEN_COUNT to the number of replacements made.

# shellcheck shell=bash
# shellcheck disable=SC2034  # SUBSTITUTE_TOKEN_COUNT consumed by sourcing router

substitute_shell_style_token() {
  local token_name="${1}"
  local token_value="${2}"
  local content_var="${3}"

  local subst_buf="${!content_var}"
  local subst_pattern="\${${token_name}}"

  if [[ "${subst_buf}" != *"${subst_pattern}"* ]]; then
    SUBSTITUTE_TOKEN_COUNT=0
    return 0
  fi

  local subst_count=0
  local subst_result=""
  local subst_remainder="${subst_buf}"
  while [[ "${subst_remainder}" == *"${subst_pattern}"* ]]; do
    # shellcheck disable=SC2295 # token_name is validated by token-name-validators (no glob chars)
    local subst_prefix="${subst_remainder%%\$\{${token_name}\}*}"
    # shellcheck disable=SC2295 # token_name is validated by token-name-validators (no glob chars)
    local subst_suffix="${subst_remainder#*\$\{${token_name}\}}"
    subst_result="${subst_result}${subst_prefix}${token_value}"
    subst_remainder="${subst_suffix}"
    subst_count=$((subst_count + 1))
  done
  subst_result="${subst_result}${subst_remainder}"

  printf -v "${content_var}" '%s' "${subst_result}"
  SUBSTITUTE_TOKEN_COUNT="${subst_count}"
}
