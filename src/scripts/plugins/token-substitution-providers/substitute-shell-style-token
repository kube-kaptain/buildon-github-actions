#
# substitute-shell-style-token - Substitutes a single shell-style ${TOKEN} in a file
#
# Sourced by substitute-tokens-from-dir. Defines substitute_shell_style_token()
# which writes the replacement count into SUBSTITUTE_TOKEN_COUNT. The router
# sources this once and calls the function in its hot loop, avoiding
# fork+exec per (token, file) pair.
#
# Function:
#   substitute_shell_style_token <token-file> <target-file>
#     Token file path is relative to the current dir and becomes the token name.
#     Target file is an absolute path; substitution is in-place.
#     Sets SUBSTITUTE_TOKEN_COUNT to the number of replacements made.
#     Returns 1 on missing-file errors.
#
# Environment:
#   CONFIG_VALUE_TRAILING_NEWLINE - How to handle trailing newlines in token
#                                   values (passed through to
#                                   prepare_token_name_and_value)

# shellcheck shell=bash
# shellcheck disable=SC2034  # SUBSTITUTE_TOKEN_COUNT consumed by sourcing router

substitute_shell_style_token() {
  local TOKEN_FILE="${1}"
  local TARGET="${2}"

  if [[ ! -f "${TOKEN_FILE}" ]]; then
    log_error "Token file not found: ${TOKEN_FILE}"
    return 1
  fi
  if [[ ! -f "${TARGET}" ]]; then
    log_error "Target file not found: ${TARGET}"
    return 1
  fi

  # Pre-declare locals so prepare_token_name_and_value assigns to the
  # function frame (via dynamic scope) rather than leaking globals.
  local TOKEN_NAME TOKEN_VALUE
  prepare_token_name_and_value "${TOKEN_FILE}"

  local file="${TARGET}"
  local token_name="${TOKEN_NAME}"
  local value="${TOKEN_VALUE}"
  local count=0
  local content
  content=$(cat "${file}" && echo x)
  content="${content%x}"

  # Pattern: ${TOKEN_NAME}
  local pattern="\${${token_name}}"
  if [[ "${content}" != *"${pattern}"* ]]; then
    SUBSTITUTE_TOKEN_COUNT="${count}"
    return 0
  fi

  local result=""
  local remainder="${content}"
  while [[ "${remainder}" == *"${pattern}"* ]]; do
    # shellcheck disable=SC2295 # token_name is validated by token-name-validators (no glob chars)
    local prefix="${remainder%%\$\{${token_name}\}*}"
    # shellcheck disable=SC2295 # token_name is validated by token-name-validators (no glob chars)
    local suffix="${remainder#*\$\{${token_name}\}}"
    result="${result}${prefix}${value}"
    remainder="${suffix}"
    count=$((count + 1))
  done
  result="${result}${remainder}"

  printf '%s' "${result}" > "${file}"
  SUBSTITUTE_TOKEN_COUNT="${count}"
}
