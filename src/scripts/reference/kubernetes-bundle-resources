run_step "docker-platform-setup"
run_step "hook-pre-tagging-tests"
run_step "versions-and-naming"
run_step "hook-post-versions-and-naming"
run_step "change-source-note-write"
run_step "release-change-data-generate"
run_step "release-change-data-oci-package"
run_step "hook-pre-package-prepare"
run_step "kubernetes-manifests-package-prepare"
run_step "kubernetes-manifests-package-only-token-override"
run_step "kubernetes-manifests-package"
run_step "kubernetes-manifests-repo-provider-package"
run_step "hook-post-package-tests"
run_step "docker-multi-tag"
run_step "git-push-tag"
run_step "kubernetes-manifests-repo-provider-publish"
run_step "docker-push-all"
run_step "hook-post-build"

# CI provider: release file preparation, release creation

print_build_complete
