#
# Spec Package Prepare
#
# Copies spec YAML files from src/specs/ (if present) to the output directory,
# converts all YAML files in the output directory to JSON, and generates a
# Dockerfile that bundles all spec files into an OCI image.
#
# Spec files may also be placed in the output yaml directory by a
# hook-post-versions-and-naming hook before this script runs. Files from both
# sources are processed together.
#
# Fails if a file from src/specs/ would overwrite a hook-generated file in the
# destination (name collision after versioning). Fails if no yaml files are
# available to package from either source.
#
# Token substitution is handled by the docker build step.
#
# Inputs via env vars (required):
#   PROJECT_NAME      - Repository/project name (prefix for matching spec files)
#   VERSION           - Version string for output files
#   OUTPUT_SUB_PATH   - Base directory for output files
#
# Inputs via env vars (optional):
#   SPEC_PACKAGING_BASE_IMAGE - Base image for Dockerfile (default: scratch)
#
# Outputs:
#   SPEC_DOCKER_FILES    - Comma-separated file list for dockerfile-substitution-files
#   DOCKERFILE_SUB_PATH  - Directory containing generated Dockerfile

set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"

# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"

log "=== Spec Package Prepare ==="

# Validate inputs
PROJECT_NAME="${PROJECT_NAME:?PROJECT_NAME is required}"
VERSION="${VERSION:?VERSION is required}"
OUTPUT_SUB_PATH="${OUTPUT_SUB_PATH:?OUTPUT_SUB_PATH is required}"
SPEC_PACKAGING_BASE_IMAGE="${SPEC_PACKAGING_BASE_IMAGE:-scratch}"

# Setup directories
specs_dir="${OUTPUT_SUB_PATH}/specs"
yaml_dir="${specs_dir}/yaml"
json_dir="${specs_dir}/json"
mkdir -p "${yaml_dir}" "${json_dir}"

# Copy fixed spec files from src/specs/ if any exist
specs_src_dir="src/specs"
if [[ -d "${specs_src_dir}" ]]; then
  unexpected_files=()
  src_spec_files=()
  for spec_file in "${specs_src_dir}"/*; do
    [[ -f "${spec_file}" ]] || continue
    fname="${spec_file##*/}"
    if [[ "${fname}" != "${PROJECT_NAME}"*.yaml ]]; then
      unexpected_files+=("${fname}")
    else
      src_spec_files+=("${spec_file}")
    fi
  done
  if [[ ${#unexpected_files[@]} -gt 0 ]]; then
    for fname in "${unexpected_files[@]}"; do
      log_error "Unexpected file in ${specs_src_dir}: ${fname} (must match ${PROJECT_NAME}*.yaml)"
    done
    log_error "${#src_spec_files[@]} valid file(s) found alongside the above"
    exit 1
  fi

  for spec_file in "${src_spec_files[@]+"${src_spec_files[@]}"}"; do
    fname="${spec_file##*/}"
    stem="${fname%.yaml}"
    versioned_yaml="${stem}-${VERSION}.yaml"
    if [[ -f "${yaml_dir}/${versioned_yaml}" ]]; then
      log_error "Collision: ${versioned_yaml} already exists in ${yaml_dir} (placed by hook) and src/specs/ also provides it"
      exit 1
    fi
    log "Copying: ${spec_file} -> ${yaml_dir}/${versioned_yaml}"
    cp "${spec_file}" "${yaml_dir}/${versioned_yaml}"
  done
fi

# Fail early if nothing to package
yaml_files=()
for f in "${yaml_dir}"/*.yaml; do
  [[ -f "${f}" ]] && yaml_files+=("${f}")
done
if [[ ${#yaml_files[@]} -eq 0 ]]; then
  log_error "No spec YAML files to package: nothing in ${yaml_dir} (add files to src/specs/ or generate them via hook-post-versions-and-naming)"
  exit 1
fi

log "Processing ${#yaml_files[@]} spec file(s)"

# Convert all yaml files to JSON and build Dockerfile entries
docker_files="Dockerfile"
dockerfile_copy_lines=()

for yaml_file in "${yaml_files[@]}"; do
  fname="${yaml_file##*/}"
  json_fname="${fname%.yaml}.json"

  log "Converting to JSON: ${json_dir}/${json_fname}"
  yq eval -o=json '.' "${yaml_file}" > "${json_dir}/${json_fname}"

  docker_files="${docker_files},yaml/${fname},json/${json_fname}"
  dockerfile_copy_lines+=("COPY yaml/${fname} /")
  dockerfile_copy_lines+=("COPY json/${json_fname} /")
done

# Generate Dockerfile (escaped tokens prevent failure with set -u)
cat > "${specs_dir}/Dockerfile" <<EOF
FROM ${SPEC_PACKAGING_BASE_IMAGE}
LABEL version="\${Version}"
LABEL project.name="\${ProjectName}"
LABEL image.name="\${DockerImageName}"
EOF
for copy_line in "${dockerfile_copy_lines[@]}"; do
  echo "${copy_line}" >> "${specs_dir}/Dockerfile"
done
log "Generated: ${specs_dir}/Dockerfile"

# Write outputs
{
  echo "SPEC_DOCKER_FILES=${docker_files}"
  echo "DOCKERFILE_SUB_PATH=${specs_dir}"
} >> "${GITHUB_OUTPUT:-/dev/stdout}"

log "Done"
