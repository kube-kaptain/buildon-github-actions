#
# vendor-helm-inject-build-details - Injects per-build annotations into every
# manifest under kaptain-out/manifests/combined/.
#
# Currently injects:
#   kaptain.org/build-timestamp: ISO-8601 UTC of this build
#   kaptain.org/built-by:        BUILD_PLATFORM
#
# Checksum-named resources (metadata.name ending '-<lowerkind>-checksum') do
# NOT receive the volatile build-timestamp - their bytes must be a pure
# function of content or the checksum churns every build. built-by is still
# injected (a platform change starts a new checksum series on purpose).
# A name ending '-checksum-<lowerkind>' (reversed marker) fails the build;
# names ending in just the kind or just '-checksum' get a warning.
#
# Why this is its own step (not in vendor-helm-render-and-process):
# the vendor flow's render output is committed under src/kubernetes/ and a
# subsequent diff check (vendor-helm-render-validate) fails the build if the
# rendered output drifts from what is committed. Per-build values would always
# trip that check. Injecting into the packaged copy after the diff check keeps
# src/kubernetes/ stable while still annotating the deployed manifests.
#
# Why sed (not yq):
# vendor-helm sed transforms can leave deploy-time tokens like ${Foo/Bar}
# inside YAML flow sequences (`values: [${Foo/Bar}]`), which yq refuses to
# parse (curly braces are flow-mapping indicators inside `[ ]`). sed-based
# insertion sidesteps the parser entirely.
#
# Anchor: the first `annotations:` line. vendor-helm-render-and-process always
# emits a top-level metadata.annotations block (kaptain.org/generated-by,
# kaptain.org/helm-upstream-chart, etc) so it is guaranteed present.
#
set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/defaults/output-sub-path.bash
source "${SCRIPT_DIR}/../defaults/output-sub-path.bash"

COMBINED_DIR="${OUTPUT_SUB_PATH}/manifests/combined"

if [[ ! -d "${COMBINED_DIR}" ]]; then
  log_error "Combined manifests directory not found: ${COMBINED_DIR}"
  log_error "Has kubernetes-manifests-package-prepare run?"
  exit 1
fi

MANIFEST_COUNT=$(find "${COMBINED_DIR}" -type f -name '*.yaml' | wc -l | tr -d ' ')

if [[ "${MANIFEST_COUNT}" -eq 0 ]]; then
  log_error "No .yaml manifests under ${COMBINED_DIR}"
  exit 1
fi

# inject_annotation <key> <value> <manifest>
#   - If the key already exists on its own line, replace the value preserving indent.
#   - Otherwise insert as the first child of the first `annotations:` block.
#   - Fails if no `annotations:` block exists (vendor-helm output is expected to have one).
inject_annotation() {
  local key="$1" value="$2" manifest="$3"
  local key_re="${key//./\\.}"

  if grep -qE "^[[:space:]]*${key_re}:" "${manifest}"; then
    sed -i.bak -E "s|^([[:space:]]*)${key_re}:.*|\\1${key}: \"${value}\"|" "${manifest}"
    rm -f "${manifest}.bak"
    return 0
  fi

  local anchor_info anchor_line anchor_text parent_indent child_indent
  anchor_info=$(grep -nE '^[[:space:]]*annotations:[[:space:]]*$' "${manifest}" | head -1 || true)
  if [[ -z "${anchor_info}" ]]; then
    log_error "No 'annotations:' line in ${manifest} (vendor-helm should always emit one)"
    exit 1
  fi
  anchor_line="${anchor_info%%:*}"
  anchor_text="${anchor_info#*:}"
  parent_indent="${anchor_text%%annotations:*}"
  child_indent="${parent_indent}  "

  # `a\` followed by a literal newline + the inserted text is the BSD-portable
  # form (also accepted by GNU sed). The trailing newline closes the insert.
  sed -i.bak "${anchor_line}a\\
${child_indent}${key}: \"${value}\"
" "${manifest}"
  rm -f "${manifest}.bak"
}

# extract_kind <manifest> - first top-level kind: value (quotes stripped)
extract_kind() {
  grep -m1 -E '^kind:' "$1" | awk '{print $2}' | tr -d '"' | tr -d "'"
}

# extract_name <manifest> - metadata.name from the first metadata: block
extract_name() {
  sed -n '/^metadata:/,/^[^ ]/p' "$1" | grep -m1 -E '^  name:' | awk '{print $2}' | tr -d '"' | tr -d "'"
}

BUILD_TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

log "Injecting kaptain.org/build-timestamp=${BUILD_TIMESTAMP}, kaptain.org/built-by=${BUILD_PLATFORM} into ${MANIFEST_COUNT} manifest(s)..."

while IFS= read -r manifest; do
  rel_path="${manifest#"${COMBINED_DIR}"/}"

  kind=$(extract_kind "${manifest}")
  name=$(extract_name "${manifest}")
  lower_kind=$(echo "${kind}" | tr '[:upper:]' '[:lower:]')

  if [[ -n "${lower_kind}" && -n "${name}" ]]; then
    # Reversed marker is always a mistake - fail before it causes confusion
    # downstream (the checksum pass keys off '-<lowerkind>-checksum').
    if [[ "${name}" == *"-checksum-${lower_kind}" ]]; then
      log_error "Reversed checksum marker in ${rel_path}: metadata.name '${name}' ends with '-checksum-${lower_kind}'; the marker is '-${lower_kind}-checksum'"
      exit 1
    fi

    # Checksum-named resources must stay byte-stable per content: no volatile
    # build-timestamp. built-by stays - a platform change intentionally
    # starts a new checksum series. Mirrors generate_metadata's rule; see
    # todo-checked/PreEnvFixes.md.
    if [[ "${name}" == *"-${lower_kind}-checksum" ]]; then
      inject_annotation "kaptain.org/built-by" "${BUILD_PLATFORM}" "${manifest}"
      log "  ✓ ${rel_path} (checksum-named: build-timestamp skipped)"
      continue
    fi

    if [[ "${name}" == *"-checksum" ]]; then
      log_warning "${rel_path}: metadata.name '${name}' ends with '-checksum' but not '-${lower_kind}-checksum'; not treated as checksum-named"
    elif [[ "${name}" == *"-${lower_kind}" ]]; then
      log_warning "${rel_path}: metadata.name '${name}' ends with '-${lower_kind}'; append '-checksum' if content-addressed naming was intended"
    fi
  fi

  inject_annotation "kaptain.org/build-timestamp" "${BUILD_TIMESTAMP}" "${manifest}"
  inject_annotation "kaptain.org/built-by" "${BUILD_PLATFORM}" "${manifest}"

  log "  ✓ ${rel_path}"
done < <(find "${COMBINED_DIR}" -type f -name '*.yaml')

log "Build details injection complete."
