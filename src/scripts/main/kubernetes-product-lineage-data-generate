#
# kubernetes-product-lineage-data-generate - Emit the product lineage data ConfigMap.
#
# Builds a single ConfigMap that serves both as a presence indicator (queried by
# operators via kaptain.org/role=kaptain-product-lineage-data) and as a lineage record (its
# data carries the verbatim spec.contents, the resolved versions, the manifests
# contract, and the full resource inventory of the product).
#
# Slots in between manifest-contract-generate and manifest-package, so its
# inventory reflects the post-substitution manifests tree and the contract is
# already on disk.
#
# Inputs (env):
#   PROJECT_NAME            - Required; product's project name (e.g. product-foo)
#   VERSION                 - Required; carried for log clarity
#   PRODUCT_NAME            - Required; verbatim PROJECT_NAME (set by product-aggregate)
#   PRODUCT_SHORT_NAME      - Required; PROJECT_NAME with product- stripped
#   TOKEN_DELIMITER_STYLE   - Token delimiter style (default shell)
#   TOKEN_NAME_STYLE        - Token name style (default PascalCase)
#   OUTPUT_SUB_PATH         - Build output dir (default kaptain-out)
#   KAPTAINPM_FILE          - Path to final KaptainPM.yaml (default kaptainpm/final/KaptainPM.yaml)
#   GIT_SHA                 - Optional; sets kaptain.org/git-sha annotation
#   BUILD_PLATFORM          - Optional; flows through to generator's built-by annotation
#
# Outputs: none (writes a file into the substituted manifests tree)
#
# Output layout (under ${OUTPUT_SUB_PATH}):
#   product-aggregate/product-lineage-data/        - 4 data files (one per CM data key)
#   product-aggregate/generated-configmap/         - generator's output dir
#   product-aggregate/substitute-staging/          - sub-round substitute target
#   manifests/substituted/${PROJECT_NAME}/<reserved> - final landing spot (cp, not mv)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/defaults/output-sub-path.bash
source "${SCRIPT_DIR}/../defaults/output-sub-path.bash"
# shellcheck source=src/scripts/defaults/tokens.bash
source "${SCRIPT_DIR}/../defaults/tokens.bash"
# shellcheck source=src/scripts/defaults/manifests-sub-path.bash
source "${SCRIPT_DIR}/../defaults/manifests-sub-path.bash"
# shellcheck source=src/scripts/lib/token-format.bash
source "${SCRIPT_DIR}/../lib/token-format.bash"

PROJECT_NAME="${PROJECT_NAME:?PROJECT_NAME is required}"
VERSION="${VERSION:?VERSION is required}"
PRODUCT_NAME="${PRODUCT_NAME:?PRODUCT_NAME is required}"
PRODUCT_SHORT_NAME="${PRODUCT_SHORT_NAME:?PRODUCT_SHORT_NAME is required}"
KAPTAINPM_FILE="${KAPTAINPM_FILE:-kaptainpm/final/KaptainPM.yaml}"
GIT_SHA="${GIT_SHA:-}"

PRODUCT_LINEAGE_DATA_FILENAME="kaptain-product-lineage-data.yaml"
BUILD_KIND_LITERAL="kubernetes-product-aggregate"
LINEAGE_DATA_ROLE_LITERAL="kaptain-product-lineage-data"

AGGREGATE_BASE="${OUTPUT_SUB_PATH}/product-aggregate"
LINEAGE_DATA_DIR="${AGGREGATE_BASE}/product-lineage-data"
GENERATED_CONFIGMAP_BASE="${AGGREGATE_BASE}/generated-configmap"
SUBSTITUTE_STAGING_DIR="${AGGREGATE_BASE}/substitute-staging"
# Scratch dir for working files. Must be a peer of LINEAGE_DATA_DIR (not a
# child) because generate-kubernetes-configmap turns every file inside
# LINEAGE_DATA_DIR into a CM data key.
SCRATCH_DIR="${AGGREGATE_BASE}/scratch"

CONTENT_RESOLVED_FILE="${OUTPUT_SUB_PATH}/content/contents-resolved.yaml"
CONTRACT_FILE="${OUTPUT_SUB_PATH}/manifests/contract/contract.yaml"
SUBSTITUTED_PRODUCT_DIR="${MANIFESTS_SUBSTITUTED_SUB_PATH}/${PROJECT_NAME}"

# Build the resources.yaml inventory by walking the substituted product tree.
# Each yaml file may contain multiple documents; emit one entry per non-null
# document with both kind and metadata.name. Sort by (path, kind, name) under
# LC_ALL=C for deterministic, locale-independent order. Append the lineage data CM's
# self-reference last using the project-name token so the sub-round substitute
# resolves it to the same concrete name the rest of the resources already have.
build_resources_inventory() {
  local product_dir="$1"
  local out_file="$2"
  local self_path="$3"
  local self_name_token="$4"

  local entries_tmp
  entries_tmp="${SCRATCH_DIR}/$(basename "${out_file}").entries"
  : > "${entries_tmp}"

  if [[ -d "${product_dir}" ]]; then
    local file rel docs line kind name
    while IFS= read -r -d '' file; do
      rel="${file#"${product_dir}/"}"
      docs=$(yq eval '
        select(.kind != null and .metadata.name != null)
        | [.kind, .metadata.name] | @tsv
      ' "${file}" 2>/dev/null || true)
      [[ -z "${docs}" ]] && continue
      while IFS= read -r line; do
        [[ -z "${line}" ]] && continue
        kind="${line%%$'\t'*}"
        name="${line#*$'\t'}"
        printf '%s\t%s\t%s\n' "${rel}" "${kind}" "${name}" >> "${entries_tmp}"
      done <<< "${docs}"
    done < <(find "${product_dir}" -type f -name '*.yaml' -print0)
  fi

  printf '%s\t%s\t%s\n' "${self_path}" "ConfigMap" "${self_name_token}" >> "${entries_tmp}"

  : > "${out_file}"
  local path kind name
  while IFS=$'\t' read -r path kind name; do
    [[ -z "${path}" ]] && continue
    {
      printf -- '- path: %s\n' "${path}"
      printf -- '  kind: %s\n' "${kind}"
      printf -- '  name: %s\n' "${name}"
    } >> "${out_file}"
  done < <(LC_ALL=C sort "${entries_tmp}")
}

main() {
  log "=== Kubernetes Product Lineage Data Generate ==="
  log "Project: ${PROJECT_NAME}"
  log "Version: ${VERSION}"
  log "Output: ${OUTPUT_SUB_PATH}"
  log "Token style: ${TOKEN_DELIMITER_STYLE}-${TOKEN_NAME_STYLE}"
  log "==========================================="

  if [[ ! -d "${SUBSTITUTED_PRODUCT_DIR}" ]]; then
    log_error "Substituted product directory not found: ${SUBSTITUTED_PRODUCT_DIR}"
    log_error "Did kubernetes-manifests-substitute run first?"
    exit 1
  fi
  if [[ ! -f "${CONTRACT_FILE}" ]]; then
    log_error "Contract file not found: ${CONTRACT_FILE}"
    log_error "Did kubernetes-manifests-contract-generate run first?"
    exit 1
  fi
  if [[ ! -f "${CONTENT_RESOLVED_FILE}" ]]; then
    log_error "Resolved-contents file not found: ${CONTENT_RESOLVED_FILE}"
    log_error "Did kubernetes-product-aggregate run first?"
    exit 1
  fi
  if [[ ! -f "${KAPTAINPM_FILE}" ]]; then
    log_error "KaptainPM file not found: ${KAPTAINPM_FILE}"
    exit 1
  fi
  if [[ ! -d "${MANIFESTS_CONFIG_SUB_PATH}" ]]; then
    log_error "Tokens directory not found: ${MANIFESTS_CONFIG_SUB_PATH}"
    log_error "Did kubernetes-manifests-package-prepare run first?"
    exit 1
  fi

  rm -rf "${LINEAGE_DATA_DIR}" "${GENERATED_CONFIGMAP_BASE}" "${SUBSTITUTE_STAGING_DIR}" "${SCRATCH_DIR}"
  mkdir -p "${LINEAGE_DATA_DIR}" "${SUBSTITUTE_STAGING_DIR}" "${SCRATCH_DIR}"

  log ""
  log "Assembling lineage data files..."

  yq eval '.spec.contents' "${KAPTAINPM_FILE}" > "${LINEAGE_DATA_DIR}/contents.yaml"
  cp "${CONTENT_RESOLVED_FILE}" "${LINEAGE_DATA_DIR}/contents-resolved.yaml"
  cp "${CONTRACT_FILE}" "${LINEAGE_DATA_DIR}/contract.yaml"

  local project_name_token
  project_name_token=$(format_canonical_token "${TOKEN_DELIMITER_STYLE}" "${TOKEN_NAME_STYLE}" "PROJECT_NAME")
  build_resources_inventory \
    "${SUBSTITUTED_PRODUCT_DIR}" \
    "${LINEAGE_DATA_DIR}/resources.yaml" \
    "${PRODUCT_LINEAGE_DATA_FILENAME}" \
    "${project_name_token}"

  log "  contents.yaml          ($(wc -l < "${LINEAGE_DATA_DIR}/contents.yaml" | tr -d ' ') lines)"
  log "  contents-resolved.yaml ($(wc -l < "${LINEAGE_DATA_DIR}/contents-resolved.yaml" | tr -d ' ') lines)"
  log "  contract.yaml          ($(wc -l < "${LINEAGE_DATA_DIR}/contract.yaml" | tr -d ' ') lines)"
  log "  resources.yaml         ($(wc -l < "${LINEAGE_DATA_DIR}/resources.yaml" | tr -d ' ') lines)"

  local product_short_name_token
  product_short_name_token=$(format_canonical_token "${TOKEN_DELIMITER_STYLE}" "${TOKEN_NAME_STYLE}" "PRODUCT_SHORT_NAME")

  local additional_labels="kaptain.org/role=${LINEAGE_DATA_ROLE_LITERAL}"
  additional_labels="${additional_labels},kaptain.org/build-kind=${BUILD_KIND_LITERAL}"
  additional_labels="${additional_labels},kaptain.org/product-name=${project_name_token}"
  additional_labels="${additional_labels},kaptain.org/product-short-name=${product_short_name_token}"

  local additional_annotations=""
  if [[ -n "${GIT_SHA}" ]]; then
    additional_annotations="kaptain.org/git-sha=${GIT_SHA}"
  fi

  log ""
  log "Generating product lineage data ConfigMap..."
  PROJECT_NAME="${PROJECT_NAME}" \
  VERSION="${VERSION}" \
  PRODUCT_NAME="${PRODUCT_NAME}" \
  PRODUCT_SHORT_NAME="${PRODUCT_SHORT_NAME}" \
  TOKEN_DELIMITER_STYLE="${TOKEN_DELIMITER_STYLE}" \
  TOKEN_NAME_STYLE="${TOKEN_NAME_STYLE}" \
  OUTPUT_SUB_PATH="${GENERATED_CONFIGMAP_BASE}" \
  KUBERNETES_CONFIGMAP_SUB_PATH="${LINEAGE_DATA_DIR}" \
  KUBERNETES_CONFIGMAP_NAME_SUFFIX="" \
  KUBERNETES_CONFIGMAP_COMBINED_SUB_PATH="" \
  KUBERNETES_CONFIGMAP_NAME_CHECKSUM_INJECTION="false" \
  KUBERNETES_CONFIGMAP_ADDITIONAL_LABELS="${additional_labels}" \
  KUBERNETES_CONFIGMAP_ADDITIONAL_ANNOTATIONS="${additional_annotations}" \
  BUILD_PLATFORM="${BUILD_PLATFORM:-}" \
  "${SCRIPT_DIR}/../generators/generate-kubernetes-configmap"

  local generated_configmap="${GENERATED_CONFIGMAP_BASE}/manifests/combined/configmap.yaml"
  if [[ ! -f "${generated_configmap}" ]]; then
    log_error "Product lineage data ConfigMap not produced at expected path: ${generated_configmap}"
    exit 1
  fi

  log ""
  log "Staging for sub-round substitute..."
  cp "${generated_configmap}" "${SUBSTITUTE_STAGING_DIR}/${PRODUCT_LINEAGE_DATA_FILENAME}"

  log ""
  log "Running sub-round token substitute against staging..."
  CONFIG_VALUE_TRAILING_NEWLINE="${CONFIG_VALUE_TRAILING_NEWLINE}" \
  TOKEN_SUBSTITUTION_PASSES="${TOKEN_SUBSTITUTION_PASSES}" \
  "${SCRIPT_DIR}/../util/substitute-tokens-from-dir" \
    "${TOKEN_DELIMITER_STYLE}" \
    "${MANIFESTS_CONFIG_SUB_PATH}" \
    "${SUBSTITUTE_STAGING_DIR}/${PRODUCT_LINEAGE_DATA_FILENAME}"

  log ""
  log "Copying into substituted product tree..."
  cp "${SUBSTITUTE_STAGING_DIR}/${PRODUCT_LINEAGE_DATA_FILENAME}" \
    "${SUBSTITUTED_PRODUCT_DIR}/${PRODUCT_LINEAGE_DATA_FILENAME}"

  log ""
  log "=== Product Lineage Data Generate Complete ==="
}

main "$@"
