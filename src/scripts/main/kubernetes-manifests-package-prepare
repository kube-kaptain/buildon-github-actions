# kubernetes-manifests-package-prepare - Prepares manifests, tokens, and defaults for packaging
#
# Sets up directory structure, copies source manifests, prepares substitution tokens,
# and assembles the final defaults dir consumed by kubernetes-manifests-contract-generate.
# Called before kubernetes-manifests-package (the "do" step).
#
# Inputs (environment variables):
#   MANIFESTS_SUB_PATH             - Source directory, relative (default: src/kubernetes)
#   DEFAULTS_SUB_PATH              - Source directory for default values (default: src/defaults)
#   ALLOW_LOCAL_DEFAULTS_OVERRIDE  - Allow local defaults to override additional-defaults on collision (default: false)
#   ALLOW_LOCAL_MANIFESTS_OVERRIDE - Allow local manifests to override additional-manifests on collision (default: false)
#   PROJECT_NAME                   - For variable substitution (required)
#   VERSION                        - For variable substitution (required)
#   VERSION_MAJOR                  - Major version component (required)
#   VERSION_MINOR                  - Minor version component (required)
#   VERSION_PATCH                  - Patch version component (required)
#   VERSION_2_PART                 - Major.Minor version (required)
#   VERSION_3_PART                 - Major.Minor.Patch version (required)
#   VERSION_4_PART                 - 4-part version (required)
#   VERSION_DNS_SAFE               - Version with dots replaced by hyphens (required)
#   VERSION_2_PART_DNS_SAFE        - 2-part DNS-safe version (required)
#   VERSION_3_PART_DNS_SAFE        - 3-part DNS-safe version (required)
#   VERSION_4_PART_DNS_SAFE        - 4-part DNS-safe version (required)
#   GIT_TAG                        - Git tag (required)
#   IS_RELEASE                     - Release flag (required)
#   OUTPUT_SUB_PATH                - Build output directory, relative (default: kaptain-out)
#   DOCKER_TAG                     - Docker tag for substitution (required)
#   DOCKER_IMAGE_NAME              - Docker image name for substitution (required)
#   DOCKER_IMAGE_FULL_URI          - Full Docker image URI for substitution (optional)
#   TARGET_REGISTRY                - Target registry for substitution (optional)
#   TARGET_NAMESPACE               - Target namespace for substitution (optional)
#   TOKEN_DELIMITER_STYLE          - Token delimiter syntax (default: shell)
#   TOKEN_NAME_STYLE               - Case style for token names (default: PascalCase)
#   TOKEN_NAME_VALIDATION          - How to validate user token names (default: MATCH)
#   ALLOW_BUILTIN_TOKEN_OVERRIDE   - Allow user tokens to override built-ins (default: false)
#   CONFIG_SUB_PATH                - Source directory for user-defined tokens, relative (default: src/config)
#   CONFIG_VALUE_TRAILING_NEWLINE  - Trailing newline handling (default: strip-for-single-line)
#
# Outputs:
#   MANIFESTS_ZIP_FILE_NAME - Filename of zip (for subsequent steps)
#
set -euo pipefail

# Locate script directory for calling sibling scripts
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Required inputs
PROJECT_NAME="${PROJECT_NAME:?PROJECT_NAME is required}"
VERSION="${VERSION:?VERSION is required}"
VERSION_MAJOR="${VERSION_MAJOR:?VERSION_MAJOR is required}"
VERSION_MINOR="${VERSION_MINOR:?VERSION_MINOR is required}"
VERSION_PATCH="${VERSION_PATCH:?VERSION_PATCH is required}"
VERSION_2_PART="${VERSION_2_PART:?VERSION_2_PART is required}"
VERSION_3_PART="${VERSION_3_PART:?VERSION_3_PART is required}"
VERSION_4_PART="${VERSION_4_PART:?VERSION_4_PART is required}"
VERSION_DNS_SAFE="${VERSION_DNS_SAFE:?VERSION_DNS_SAFE is required}"
VERSION_2_PART_DNS_SAFE="${VERSION_2_PART_DNS_SAFE:?VERSION_2_PART_DNS_SAFE is required}"
VERSION_3_PART_DNS_SAFE="${VERSION_3_PART_DNS_SAFE:?VERSION_3_PART_DNS_SAFE is required}"
VERSION_4_PART_DNS_SAFE="${VERSION_4_PART_DNS_SAFE:?VERSION_4_PART_DNS_SAFE is required}"
GIT_TAG="${GIT_TAG:?GIT_TAG is required}"
DOCKER_TAG="${DOCKER_TAG:?DOCKER_TAG is required}"
DOCKER_IMAGE_NAME="${DOCKER_IMAGE_NAME:?DOCKER_IMAGE_NAME is required}"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/defaults/output-sub-path.bash
source "${SCRIPT_DIR}/../defaults/output-sub-path.bash"
# shellcheck source=src/scripts/defaults/manifests-sub-path.bash
source "$(dirname "${BASH_SOURCE[0]}")/../defaults/manifests-sub-path.bash"

# Pass-through vars (called scripts default their own; these just satisfy set -u)
DOCKER_IMAGE_FULL_URI="${DOCKER_IMAGE_FULL_URI:-}"
TARGET_REGISTRY="${TARGET_REGISTRY:-}"
TARGET_NAMESPACE="${TARGET_NAMESPACE:-}"
IS_RELEASE="${IS_RELEASE:-}"

# Token substitution
# shellcheck source=src/scripts/defaults/tokens.bash
source "$(dirname "${BASH_SOURCE[0]}")/../defaults/tokens.bash"

# shellcheck source=src/scripts/lib/output-var.bash
source "${SCRIPT_DIR}/../lib/output-var.bash"

main() {
  log "=== Kubernetes Manifest Package Prepare ==="
  log "Source: ${MANIFESTS_SUB_PATH}"
  log "Config: ${CONFIG_SUB_PATH}"
  log "Defaults: ${DEFAULTS_SUB_PATH}"
  log "Allow local defaults override: ${ALLOW_LOCAL_DEFAULTS_OVERRIDE}"
  log "Allow local manifests override: ${ALLOW_LOCAL_MANIFESTS_OVERRIDE}"
  log "Output: ${OUTPUT_SUB_PATH}"
  log "Project: ${PROJECT_NAME}"
  log "Version: ${VERSION}"
  log "Docker tag: ${DOCKER_TAG}"
  log "Docker image: ${DOCKER_IMAGE_NAME}"
  log "============================================"

  # Create output directory structure (may already exist from pre-package hooks)
  mkdir -p "${MANIFESTS_COMBINED_SUB_PATH}"
  mkdir -p "${MANIFESTS_ZIP_SUB_PATH}"

  # Copy from source to combined if source exists and has files
  # (Hooks may have already contributed to combined/ - source files override)
  if [[ -d "${MANIFESTS_SUB_PATH}" ]]; then
    local source_file_count
    source_file_count=$(find "${MANIFESTS_SUB_PATH}" -type f | wc -l | tr -d ' ')

    if [[ "${source_file_count}" -gt 0 ]]; then
      log ""
      log "Copying ${source_file_count} file(s) from ${MANIFESTS_SUB_PATH}"
      cp -R "${MANIFESTS_SUB_PATH}"/* "${MANIFESTS_COMBINED_SUB_PATH}/"
    else
      log ""
      log "Source directory empty: ${MANIFESTS_SUB_PATH}"
    fi
  else
    log ""
    log "Source directory not found: ${MANIFESTS_SUB_PATH}"
  fi

  # Foreign-contributor layer: merge additional-manifests/ into combined/.
  # Strict policy: ALLOW_LOCAL_MANIFESTS_OVERRIDE=true => local wins on conflict (WARN).
  # When false, any path collision fails the build — even byte-identical (unlike
  # defaults, where duplicate paths between layers are expected by design).
  if [[ -d "${MANIFESTS_ADDITIONAL_SUB_PATH}" ]] \
     && [[ -n "$(find "${MANIFESTS_ADDITIONAL_SUB_PATH}" -type f 2>/dev/null)" ]]; then
    local additional_manifests_count
    additional_manifests_count=$(find "${MANIFESTS_ADDITIONAL_SUB_PATH}" -type f | wc -l | tr -d ' ')
    log ""
    log "Merging ${additional_manifests_count} additional manifest(s) from ${MANIFESTS_ADDITIONAL_SUB_PATH}"

    local manifest_conflicts=()
    local extra_manifest rel_manifest target_manifest
    while IFS= read -r -d '' extra_manifest; do
      rel_manifest="${extra_manifest#"${MANIFESTS_ADDITIONAL_SUB_PATH}/"}"
      target_manifest="${MANIFESTS_COMBINED_SUB_PATH}/${rel_manifest}"

      if [[ ! -e "${target_manifest}" ]]; then
        mkdir -p "$(dirname "${target_manifest}")"
        cp "${extra_manifest}" "${target_manifest}"
        continue
      fi

      if [[ "${ALLOW_LOCAL_MANIFESTS_OVERRIDE}" == "true" ]]; then
        log_warning "local manifest '${rel_manifest}' overrides a file contributed via additional-manifests/"
        continue
      fi

      manifest_conflicts+=("${rel_manifest}")
    done < <(find "${MANIFESTS_ADDITIONAL_SUB_PATH}" -type f -print0)

    if [[ ${#manifest_conflicts[@]} -gt 0 ]]; then
      log_error "Manifest path collisions: files contributed via ${MANIFESTS_ADDITIONAL_SUB_PATH} already exist in the combined manifests (from ${MANIFESTS_SUB_PATH} or a pre-package-prepare hook):"
      for rel_manifest in "${manifest_conflicts[@]}"; do
        log_error "  ${rel_manifest}"
      done
      log_error "Either rename the colliding file, or set spec.main.manifests.allowLocalOverride: true"
      log_error "(ALLOW_LOCAL_MANIFESTS_OVERRIDE=true) if the file in combined is intentionally authoritative."
      exit 1
    fi
  fi

  # Validate combined/ has files (from any source: hooks or src/kubernetes)
  local yaml_count=0
  local other_count=0
  local total_files=0

  while IFS= read -r file; do
    total_files=$((total_files + 1))
    case "${file}" in
      *.yaml) yaml_count=$((yaml_count + 1)) ;;
      *) other_count=$((other_count + 1)) ;;
    esac
  done < <(find "${MANIFESTS_COMBINED_SUB_PATH}" -type f)

  if [[ "${total_files}" -eq 0 ]]; then
    log_error "No manifests to package (${MANIFESTS_COMBINED_SUB_PATH} is empty)"
    exit 1
  fi

  log ""
  log "Found ${yaml_count} manifest file(s) (.yaml)"
  if [[ ${other_count} -gt 0 ]]; then
    log "Found ${other_count} non-manifest file(s)"
  fi

  # Compute the zip filename (used as a built-in token)
  local zip_name="${PROJECT_NAME}-${VERSION}-manifests.zip"

  # Prepare substitution tokens (built-ins + user config)
  log ""
  TOKENS_OUTPUT_SUB_PATH="${MANIFESTS_CONFIG_SUB_PATH}" \
  CONFIG_SUB_PATH="${CONFIG_SUB_PATH}" \
  TOKEN_NAME_STYLE="${TOKEN_NAME_STYLE}" \
  TOKEN_NAME_VALIDATION="${TOKEN_NAME_VALIDATION}" \
  ALLOW_BUILTIN_TOKEN_OVERRIDE="${ALLOW_BUILTIN_TOKEN_OVERRIDE}" \
  CONFIG_VALUE_TRAILING_NEWLINE="${CONFIG_VALUE_TRAILING_NEWLINE}" \
  TOKEN_SUBSTITUTION_PASSES="${TOKEN_SUBSTITUTION_PASSES}" \
  PROJECT_NAME="${PROJECT_NAME}" \
  VERSION="${VERSION}" \
  VERSION_MAJOR="${VERSION_MAJOR}" \
  VERSION_MINOR="${VERSION_MINOR}" \
  VERSION_PATCH="${VERSION_PATCH}" \
  VERSION_2_PART="${VERSION_2_PART}" \
  VERSION_3_PART="${VERSION_3_PART}" \
  VERSION_4_PART="${VERSION_4_PART}" \
  VERSION_DNS_SAFE="${VERSION_DNS_SAFE}" \
  VERSION_2_PART_DNS_SAFE="${VERSION_2_PART_DNS_SAFE}" \
  VERSION_3_PART_DNS_SAFE="${VERSION_3_PART_DNS_SAFE}" \
  VERSION_4_PART_DNS_SAFE="${VERSION_4_PART_DNS_SAFE}" \
  GIT_TAG="${GIT_TAG}" \
  DOCKER_TAG="${DOCKER_TAG}" \
  DOCKER_IMAGE_NAME="${DOCKER_IMAGE_NAME}" \
  DOCKER_IMAGE_FULL_URI="${DOCKER_IMAGE_FULL_URI}" \
  TARGET_REGISTRY="${TARGET_REGISTRY}" \
  TARGET_NAMESPACE="${TARGET_NAMESPACE}" \
  IS_RELEASE="${IS_RELEASE}" \
  MANIFESTS_ZIP_FILE_NAME="${zip_name}" \
  "${SCRIPT_DIR}/../util/prepare-substitution-tokens"

  # Copy additional tokens written by prior steps (e.g. vendor-helm retag tokens)
  local additional_tokens_dir="${OUTPUT_SUB_PATH}/manifests/additional-tokens"
  if [[ -d "${additional_tokens_dir}" ]] && [[ -n "$(find "${additional_tokens_dir}" -type f 2>/dev/null)" ]]; then
    local additional_count
    additional_count=$(find "${additional_tokens_dir}" -type f | wc -l | tr -d ' ')

    # Check for collisions against everything already in the config dir
    local collisions=()
    while IFS= read -r -d '' additional_file; do
      local token_name="${additional_file#"${additional_tokens_dir}"/}"
      if [[ -f "${MANIFESTS_CONFIG_SUB_PATH}/${token_name}" ]]; then
        collisions+=("${token_name}")
      fi
    done < <(find "${additional_tokens_dir}" -type f -print0)

    if [[ ${#collisions[@]} -gt 0 ]]; then
      log_error "Additional tokens collide with existing tokens:"
      for collision in "${collisions[@]}"; do
        log "  ${collision}"
      done
      exit 1
    fi

    log "Copying ${additional_count} additional token(s) from ${additional_tokens_dir}"
    cp -R "${additional_tokens_dir}"/* "${MANIFESTS_CONFIG_SUB_PATH}/"
  fi

  # --- Defaults: assemble the final defaults dir consumed by contract-generate ---
  # Source layer: copy ${DEFAULTS_SUB_PATH}/* into manifests/defaults/.
  # Foreign-contributor layer: merge additional-defaults/ with byte-identical-or-fail
  # policy. ALLOW_LOCAL_DEFAULTS_OVERRIDE=true => local wins on conflict (WARN).
  # Imported defaults whose token has a value in manifests/config/ are dropped:
  # substitution bakes that value into the manifests, leaving the default dead
  # weight that would trip contract-generate's orphan check. In-tree defaults
  # are never dropped - a baked in-tree default is a misconfiguration that
  # contract-generate must still catch.
  log ""
  mkdir -p "${MANIFESTS_DEFAULTS_SUB_PATH}"

  if [[ -d "${DEFAULTS_SUB_PATH}" ]] \
     && [[ -n "$(find "${DEFAULTS_SUB_PATH}" -type f 2>/dev/null)" ]]; then
    local defaults_count
    defaults_count=$(find "${DEFAULTS_SUB_PATH}" -type f | wc -l | tr -d ' ')
    log "Copying ${defaults_count} default(s) from ${DEFAULTS_SUB_PATH}"
    cp -R "${DEFAULTS_SUB_PATH}"/* "${MANIFESTS_DEFAULTS_SUB_PATH}/"
  else
    log "No source defaults found at ${DEFAULTS_SUB_PATH}"
  fi

  if [[ -d "${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}" ]] \
     && [[ -n "$(find "${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}" -type f 2>/dev/null)" ]]; then
    local additional_defaults_count
    additional_defaults_count=$(find "${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}" -type f | wc -l | tr -d ' ')
    log "Merging ${additional_defaults_count} additional default(s) from ${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}"

    local conflicts=()
    local extra_file rel target_file
    while IFS= read -r -d '' extra_file; do
      rel="${extra_file#"${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}/"}"
      target_file="${MANIFESTS_DEFAULTS_SUB_PATH}/${rel}"

      if [[ -f "${MANIFESTS_CONFIG_SUB_PATH}/${rel}" ]]; then
        log "Dropping imported default '${rel}': token is baked in by this build's config"
        continue
      fi

      if [[ ! -e "${target_file}" ]]; then
        mkdir -p "$(dirname "${target_file}")"
        cp "${extra_file}" "${target_file}"
        continue
      fi

      if cmp -s "${extra_file}" "${target_file}"; then
        continue
      fi

      if [[ "${ALLOW_LOCAL_DEFAULTS_OVERRIDE}" == "true" ]]; then
        log_warning "local default '${rel}' overrides a value contributed via additional-defaults/"
        continue
      fi

      conflicts+=("${rel}")
    done < <(find "${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}" -type f -print0)

    if [[ ${#conflicts[@]} -gt 0 ]]; then
      log_error "Default value collisions between ${DEFAULTS_SUB_PATH} and ${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}:"
      local rel local_val extra_val
      for rel in "${conflicts[@]}"; do
        local_val=$(cat "${MANIFESTS_DEFAULTS_SUB_PATH}/${rel}")
        extra_val=$(cat "${MANIFESTS_ADDITIONAL_DEFAULTS_SUB_PATH}/${rel}")
        log_error "  ${rel}"
        log_error "    local:      ${local_val}"
        log_error "    additional: ${extra_val}"
      done
      log_error "Either align the values, or set spec.main.manifests.defaults.allowLocalOverride: true"
      log_error "(ALLOW_LOCAL_DEFAULTS_OVERRIDE=true) if the local value is intentionally authoritative."
      exit 1
    fi
  fi

  output_var "MANIFESTS_ZIP_FILE_NAME" "${zip_name}"

  log ""
  log "=== Prepare Complete ==="
}

main "$@"
