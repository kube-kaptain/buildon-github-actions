# Load the final merged KaptainPM.yaml and export values as environment variables.
# Run from repo root after kaptain-init has written kaptainpm/final/KaptainPM.yaml.
# Uses output_var() to export via GITHUB_OUTPUT, REFERENCE_SCRIPT_OUTPUT, and direct export.
#
# Validates that the kind field matches the expected kind from the build wrapper
# before loading any fields.
#
# Inputs via env vars (required):
#   BUILD_KIND - The kind value from the build wrapper (exact kebab-case match)
set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"

# shellcheck source=src/scripts/lib/output-var.bash
source "${SCRIPT_DIR}/../lib/output-var.bash"

PM_FILE="kaptainpm/final/KaptainPM.yaml"

if [[ ! -f "${PM_FILE}" ]]; then
  log_error "Project manifest not found: ${PM_FILE}"
  log_error "Has kaptain-init run? Expected final merged file at ${PM_FILE}"
  exit 1
fi

if ! command -v yq &> /dev/null; then
  log_error "yq is required but not installed"
  exit 1
fi

# Validate YAML syntax before reading
if ! yq eval '.' "${PM_FILE}" > /dev/null 2>&1; then
  log_error "Invalid YAML syntax in ${PM_FILE}"
  log "$(yq eval '.' "${PM_FILE}" 2>&1 | head -5)"
  exit 1
fi

# Kind validation - must match build wrapper's expected kind exactly
BUILD_KIND="${BUILD_KIND:?BUILD_KIND is required}"
log "Reading kind from ${PM_FILE}..."
log "$(yq -r '.kind // ""' "${PM_FILE}" 2>&1 || true)"
actual_kind=$(yq -r '.kind // ""' "${PM_FILE}")
if [[ -z "${actual_kind}" ]]; then
  log_error "KaptainPM.yaml does not declare a kind"
  exit 1
fi
if [[ "${actual_kind}" != "${BUILD_KIND}" ]]; then
  log_error "Kind mismatch: KaptainPM.yaml declares '${actual_kind}' but build wrapper expects '${BUILD_KIND}'"
  exit 1
fi
log "Kind matched: ${actual_kind}"

