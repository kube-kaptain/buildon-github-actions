  value=$(yq -r ".${yaml_path} // \"\"" "${PM_FILE}" )

  # Skip if value is empty, null, or an object/array marker
  if [[ -z "${value}" || "${value}" == "null" || "${value}" == "{}" || "${value}" == "[]" ]]; then
    continue
