#
# Layer Package Prepare
#
# Detects layer vs layerset from PROJECT_NAME prefix, copies source files
# to the build context directory, injects build metadata, resolves version
# ranges (layersets), converts YAML to JSON, and generates Dockerfile +
# .dockerignore for an OCI scratch image.
#
# Inputs via env vars (required):
#   PROJECT_NAME      - Repository/project name (must start with layer- or layerset-)
#   VERSION           - Version string
#   REPOSITORY_OWNER  - Repository owner (for metadata injection)
#   REPOSITORY_NAME   - Repository name (for metadata injection)
#
# Inputs via env vars (optional):
#   OUTPUT_SUB_PATH            - Build output directory (default: kaptain-out)
#   LAYER_PACKAGING_BASE_IMAGE - Base image for Dockerfile (default: scratch)
#   BUILD_PLATFORM             - Build platform identifier (for metadata)
#
# Outputs:
#   LAYER_TYPE                        - "layer" or "layerset"
#   DOCKERFILE_SUBSTITUTION_FILES     - Comma-separated file list for docker-build-dockerfile
#   DOCKERFILE_SUB_PATH               - Directory containing generated Dockerfile
#   DOCKERFILE_SUB_PATH_LINUX_AMD64   - Same (single context for all platforms)
#   DOCKERFILE_SUB_PATH_LINUX_ARM64   - Same

set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/defaults/output-sub-path.bash
source "${SCRIPT_DIR}/../defaults/output-sub-path.bash"
# shellcheck source=src/scripts/defaults/layer-build.bash
source "${SCRIPT_DIR}/../defaults/layer-build.bash"
# shellcheck source=src/scripts/lib/output-var.bash
source "${SCRIPT_DIR}/../lib/output-var.bash"
# shellcheck source=src/scripts/lib/version-range.bash
source "${SCRIPT_DIR}/../lib/version-range.bash"
# shellcheck source=src/scripts/lib/validate-exact-file-exists.bash
source "${SCRIPT_DIR}/../lib/validate-exact-file-exists.bash"

log "=== Layer Package Prepare ==="

# Validate inputs
PROJECT_NAME="${PROJECT_NAME:?PROJECT_NAME is required}"
VERSION="${VERSION:?VERSION is required}"
REPOSITORY_OWNER="${REPOSITORY_OWNER:?REPOSITORY_OWNER is required}"
REPOSITORY_NAME="${REPOSITORY_NAME:?REPOSITORY_NAME is required}"
DOCKER_TARGET_REGISTRY="${DOCKER_TARGET_REGISTRY:?DOCKER_TARGET_REGISTRY is required}"
DOCKER_TARGET_NAMESPACE="${DOCKER_TARGET_NAMESPACE:-}"

# Detect layer type from project name prefix or suffix.
# Layerset is checked first so that a name like "my-layerset" is classified
# as layerset rather than matching the "-layer" suffix.
if [[ "${PROJECT_NAME}" == layerset-* || "${PROJECT_NAME}" == *-layerset ]]; then
  LAYER_TYPE="layerset"
  source_dir="src/layerset"
elif [[ "${PROJECT_NAME}" == layer-* || "${PROJECT_NAME}" == *-layer ]]; then
  LAYER_TYPE="layer"
  source_dir="src/layer"
else
  log_error "PROJECT_NAME must start or end with 'layer' or 'layerset': ${PROJECT_NAME}"
  exit 1
fi
log "Layer type: ${LAYER_TYPE} (from project name: ${PROJECT_NAME})"

# Setup context directory
context_dir="${OUTPUT_SUB_PATH}/layer-build/context"
mkdir -p "${context_dir}"

# --- Locate KaptainPM.yaml: must be in exactly one of source_dir or context_dir ---
# source_dir is static input (src/layer or src/layerset). context_dir may have
# been populated by a generator/hook before this script runs. The file must
# live in exactly one place - neither is a missing-input error, both is an
# ambiguous-input error.
source_has_pm=false
context_has_pm=false
file_exists_any_case "${source_dir}" "KaptainPM.yaml" && source_has_pm=true
file_exists_any_case "${context_dir}" "KaptainPM.yaml" && context_has_pm=true

if ! ${source_has_pm} && ! ${context_has_pm}; then
  log_error "KaptainPM.yaml not found in ${source_dir}/ or ${context_dir}/"
  log_error "Provide it as source in ${source_dir}/ or generate it into ${context_dir}/"
  exit 1
fi
if ${source_has_pm} && ${context_has_pm}; then
  log_error "KaptainPM.yaml present in both ${source_dir}/ and ${context_dir}/ - pick one"
  exit 1
fi

# Validate exact case at whichever location has it
if ${source_has_pm}; then
  if ! validate_exact_file_exists "${source_dir}" "KaptainPM.yaml"; then
    log_error "KaptainPM.yaml in ${source_dir}/ failed validation - fix the case or remove duplicate variants before building"
    exit 1
  fi
else
  if ! validate_exact_file_exists "${context_dir}" "KaptainPM.yaml"; then
    log_error "KaptainPM.yaml in ${context_dir}/ failed validation - fix the case or remove duplicate variants before building"
    exit 1
  fi
fi

# Layerset input shape: only KaptainPM.yaml is allowed in source_dir/context_dir
# at this point. The XOR above guarantees exactly one place has the file.
if [[ "${LAYER_TYPE}" == "layerset" ]]; then
  if [[ -d "${source_dir}" ]]; then
    for f in "${source_dir}"/*; do
      [[ -e "${f}" ]] || continue
      fname="${f##*/}"
      if [[ "${fname}" != "KaptainPM.yaml" ]]; then
        log_error "Unexpected file in ${source_dir}/: ${fname} (layersets must contain only KaptainPM.yaml)"
        exit 1
      fi
    done
  fi
  for f in "${context_dir}"/*; do
    [[ -e "${f}" ]] || continue
    fname="${f##*/}"
    if [[ "${fname}" != "KaptainPM.yaml" ]]; then
      log_error "Unexpected file in ${context_dir}/: ${fname} (layersets must contain only KaptainPM.yaml)"
      exit 1
    fi
  done
fi

# Copy source files into context_dir (if source_dir exists and has content)
# Layer: copy everything (static files plus KaptainPM.yaml if in source).
#        Static files may collide with generated context - static wins, by design.
# Layerset: copy only KaptainPM.yaml if it was in source_dir (nothing else allowed).
if [[ -d "${source_dir}" ]]; then
  if [[ "${LAYER_TYPE}" == "layerset" ]]; then
    if ${source_has_pm}; then
      log "Copying KaptainPM.yaml from ${source_dir}/"
      cp "${source_dir}/KaptainPM.yaml" "${context_dir}/"
    fi
  else
    log "Copying source files from ${source_dir}/"
    cp -a "${source_dir}"/. "${context_dir}/"
  fi
fi

# apiVersion enforcement: layer KaptainPM.yaml must declare apiVersion >= build schema version
if [[ ! -f "${LAYER_SCHEMA_VERSION_FILE}" ]]; then
  log_error "Schema version file not found: ${LAYER_SCHEMA_VERSION_FILE}"
  exit 1
fi
build_schema_version=$(cat "${LAYER_SCHEMA_VERSION_FILE}")

declared_api_version=$(yq -r '.apiVersion // ""' "${context_dir}/KaptainPM.yaml")
if [[ -z "${declared_api_version}" ]]; then
  log_error "KaptainPM.yaml does not declare an apiVersion"
  exit 1
fi
# Strip kaptain.org/ prefix for numeric comparison
declared_version="${declared_api_version#kaptain.org/}"

if version_lt "${declared_version}" "${build_schema_version}"; then
  log_error "apiVersion ${declared_api_version} is lower than the build system's schema version ${build_schema_version}"
  log_error "Update the apiVersion in your KaptainPM.yaml to at least kaptain.org/${build_schema_version}"
  exit 1
fi
log "apiVersion check passed: ${declared_api_version} >= kaptain.org/${build_schema_version}"

# Validate source file against appropriate source schema
schemas_dir="${SCRIPT_DIR}/../../schemas"
if [[ "${LAYER_TYPE}" == "layerset" ]]; then
  source_schema="${schemas_dir}/spec-kaptainpm-schema-layerset-source.${build_schema_version}.json"
else
  source_schema="${schemas_dir}/spec-kaptainpm-schema-layer-source.${build_schema_version}.json"
fi

if [[ ! -f "${source_schema}" ]]; then
  log_error "Source schema not found: ${source_schema}"
  exit 1
fi
log "Validating source against schema: $(basename "${source_schema}")"
check-jsonschema --schemafile "${source_schema}" "${context_dir}/KaptainPM.yaml"
log "Source schema validation passed"

# Inject build metadata via yq - all values injected directly
log "Injecting build metadata..."
DOCKER_IMAGE_NAME="${DOCKER_IMAGE_NAME:?DOCKER_IMAGE_NAME is required}"
export SOURCE_REPO="${REPOSITORY_OWNER}/${REPOSITORY_NAME}"
if [[ -n "${DOCKER_TARGET_NAMESPACE}" ]]; then
  export IMAGE_URI="${DOCKER_TARGET_REGISTRY}/${DOCKER_TARGET_NAMESPACE}/${DOCKER_IMAGE_NAME}:${VERSION}"
else
  export IMAGE_URI="${DOCKER_TARGET_REGISTRY}/${DOCKER_IMAGE_NAME}:${VERSION}"
fi
yq eval -i '
  .metadata.labels["kaptain.org/version"] = strenv(VERSION) |
  .metadata.labels["kaptain.org/version"] style="double" |
  .metadata.labels["kaptain.org/project-name"] = strenv(PROJECT_NAME) |
  .metadata.labels["kaptain.org/owner"] = strenv(REPOSITORY_OWNER) |
  .metadata.annotations["kaptain.org/built-by"] = strenv(BUILD_PLATFORM) |
  .metadata.annotations["kaptain.org/source-repository"] = strenv(SOURCE_REPO) |
  .metadata.annotations["kaptain.org/image-uri"] = strenv(IMAGE_URI)
' "${context_dir}/KaptainPM.yaml"
log "Metadata injected"

# Layerset: resolve version ranges in spec.layers
if [[ "${LAYER_TYPE}" == "layerset" ]]; then
  log "Resolving version ranges in spec.layers..."
  UTIL_DIR="${SCRIPT_DIR}/../util"

  layer_count=$(yq -r '.spec.layers | length' "${context_dir}/KaptainPM.yaml")
  if [[ "${layer_count}" -eq 0 ]]; then
    log_error "Layerset has no entries in spec.layers"
    exit 1
  fi

  for ((i = 0; i < layer_count; i++)); do
    ref=$(yq -r ".spec.layers[${i}]" "${context_dir}/KaptainPM.yaml")

    # Check if the reference contains range syntax
    if ! version_is_exact "${ref##*:}"; then
      log "Resolving range: ${ref}"
      resolve_output_file="${OUTPUT_SUB_PATH}/artifact-resolve/${ref//[^a-zA-Z0-9._-]/_}"
      mkdir -p "$(dirname "${resolve_output_file}")"
      "${UTIL_DIR}/artifact-resolve" "${ref}" "${resolve_output_file}"
      resolved=$(< "${resolve_output_file}")
      # Extract resolved version from fully qualified URI
      resolved_version="${resolved##*:}"
      ref_name="${ref%%:*}"
      resolved_ref="${ref_name}:${resolved_version}"
      log "Resolved: ${ref} -> ${resolved_ref}"
      yq eval -i ".spec.layers[${i}] = \"${resolved_ref}\"" "${context_dir}/KaptainPM.yaml"
    fi
  done
  log "Range resolution complete"

  # Verification: every resolved layer reference must exist at the remote.
  # Range resolutions already implicitly verified existence (the version came
  # from the registry tag list), but exact references were trusted by the
  # resolver and need explicit verification here.
  log "Verifying remote existence of all spec.layers entries..."
  for ((i = 0; i < layer_count; i++)); do
    ref=$(yq -r ".spec.layers[${i}]" "${context_dir}/KaptainPM.yaml")
    if ! "${UTIL_DIR}/artifact-exists" "${ref}"; then
      log_error "Layer dependency does not exist at remote: ${ref}"
      exit 1
    fi
  done
  log "Remote existence verification complete"
fi

# Convert YAML to JSON
log "Converting KaptainPM.yaml to JSON..."
yq eval -o=json '.' "${context_dir}/KaptainPM.yaml" > "${context_dir}/KaptainPM.json"
log "Generated: ${context_dir}/KaptainPM.json"

# Generate .dockerignore
cat > "${context_dir}/.dockerignore" <<'EOF'
Dockerfile
EOF
log "Generated: ${context_dir}/.dockerignore"

# Generate Dockerfile using build args passed by docker-build-dockerfile
cat > "${context_dir}/Dockerfile" <<EOF
FROM ${LAYER_PACKAGING_BASE_IMAGE}
ARG VERSION
ARG PROJECT_NAME
ARG DOCKER_TAG
ARG DOCKER_IMAGE_NAME
ARG DOCKER_REGISTRY
ARG DOCKER_NAMESPACE
ARG DOCKER_PLATFORM
ARG DOCKER_PLATFORM_CPU_ARCHITECTURE
ARG REPOSITORY_OWNER
ARG REPOSITORY_NAME
LABEL version=\${VERSION}
LABEL project.name=\${PROJECT_NAME}
LABEL docker.tag=\${DOCKER_TAG}
LABEL image.name=\${DOCKER_IMAGE_NAME}
LABEL docker.registry=\${DOCKER_REGISTRY}
LABEL docker.namespace=\${DOCKER_NAMESPACE}
LABEL docker.platform=\${DOCKER_PLATFORM}
LABEL docker.platform.cpu.architecture=\${DOCKER_PLATFORM_CPU_ARCHITECTURE}
LABEL repository.owner=\${REPOSITORY_OWNER}
LABEL repository.name=\${REPOSITORY_NAME}
COPY . /
EOF
log "Generated: ${context_dir}/Dockerfile"

# Build the docker files list (all files that need token substitution)
if [[ "${LAYER_TOKEN_SUBSTITUTION}" == "true" ]]; then
  docker_files="Dockerfile,KaptainPM.yaml,KaptainPM.json"
else
  docker_files="Dockerfile"
fi

# Write outputs
output_var "LAYER_TYPE" "${LAYER_TYPE}"
output_var "DOCKERFILE_SUBSTITUTION_FILES" "${docker_files}"
output_var "DOCKERFILE_SUB_PATH" "${context_dir}"
output_var "DOCKERFILE_SUB_PATH_LINUX_AMD64" "${context_dir}"
output_var "DOCKERFILE_SUB_PATH_LINUX_ARM64" "${context_dir}"

log "Done"
