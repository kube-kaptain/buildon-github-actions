# Spec Validate
#
# Validates all substituted spec JSON files against their schema. Run after
# docker build has performed token substitution.
#
# Basic validation (always run): JSON syntax check via jq.
# Schema validation (always run): validates against the spec's declared schema.
#
# Inputs via env vars (required):
#   SPEC_TYPE         - Type of spec: "schema" or "api"
#   OUTPUT_SUB_PATH   - Base directory for output files
#
# Inputs via env vars (optional):
#   SPEC_JSON_SCHEMA_URL - Schema file path or URL (default: src/schemas/json-schema-draft-2020-12.json)

set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"

# shellcheck source=src/scripts/defaults/spec-validate.bash
source "${SCRIPT_DIR}/../defaults/spec-validate.bash"

# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"

log "=== Spec Validate ==="

# Validate inputs
SPEC_TYPE="${SPEC_TYPE:?SPEC_TYPE is required}"
OUTPUT_SUB_PATH="${OUTPUT_SUB_PATH:?OUTPUT_SUB_PATH is required}"
DOCKER_PLATFORM="${DOCKER_PLATFORM:-linux/amd64}"
if [[ "${DOCKER_PLATFORM}" == *,* ]]; then
  # Multi-platform: use first platform's context (content is identical)
  first_platform="${DOCKER_PLATFORM%%,*}"
  spec_sub_path="${OUTPUT_SUB_PATH}/docker-${first_platform//\//-}/substituted/json"
else
  spec_sub_path="${OUTPUT_SUB_PATH}/docker/substituted/json"
fi

# Validate SPEC_TYPE value
if [[ "${SPEC_TYPE}" != "schema" && "${SPEC_TYPE}" != "api" ]]; then
  log_error "SPEC_TYPE must be 'schema' or 'api'"
  exit 1
fi

# Find all spec files
spec_files=()
for f in "${spec_sub_path}"/*.json; do
  [[ -f "${f}" ]] && spec_files+=("${f}")
done
if [[ ${#spec_files[@]} -eq 0 ]]; then
  log_error "No JSON spec files found in ${spec_sub_path}"
  exit 1
fi

log "Type: ${SPEC_TYPE} | Files: ${#spec_files[@]}"

validate_with_check_jsonschema() {
  local spec_file="$1" schema_url="$2"
  log "Validating with check-jsonschema..."
  check-jsonschema --schemafile "${schema_url}" "${spec_file}"
}

for spec_file in "${spec_files[@]}"; do
  if [[ ! -f "${spec_file}" ]]; then
    log_error "Spec file not found: ${spec_file}"
    exit 1
  fi

  log "Validating: $(basename "${spec_file}")"

  # Always: validate JSON syntax
  if ! jq . "${spec_file}" > /dev/null 2>&1; then
    log_error "Invalid JSON syntax: $(basename "${spec_file}")"
    exit 1
  fi
  log "JSON syntax valid: $(basename "${spec_file}")"

  # Schema validation
  if [[ "${SPEC_TYPE}" == "api" ]]; then
    schema_url=$(jq -r '."$schema" // empty' "${spec_file}")
    if [[ -z "${schema_url}" ]]; then
      log_error "API spec must declare \$schema: $(basename "${spec_file}")"
      exit 1
    fi
  else
    schema_url="${SPEC_JSON_SCHEMA_URL}"
  fi
  log "Schema: ${schema_url}"
  validate_with_check_jsonschema "${spec_file}" "${schema_url}"

  log "Validation passed: $(basename "${spec_file}")"
done
