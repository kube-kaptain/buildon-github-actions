#
# Load docker registry login config from the project root KaptainPM.yaml.
#
# Reads spec.main.docker.logins from the project root KaptainPM.yaml
# before kaptain-init runs, so docker-registry-logins can authenticate before
# layer images are pulled. The full config load from the merged final happens
# later via load-final-kaptainpm-yaml.
#
# Outputs:
#   DOCKER_REGISTRY_LOGINS    - Registry login config JSON (for docker-registry-logins)

set -euo pipefail

SCRIPT_DIR="$(dirname "${0}")"

# shellcheck source=src/scripts/defaults/platform.bash
source "${SCRIPT_DIR}/../defaults/platform.bash"
# shellcheck source=src/scripts/lib/log.bash
source "${SCRIPT_DIR}/../lib/log.bash"
# shellcheck source=src/scripts/lib/output-var.bash
source "${SCRIPT_DIR}/../lib/output-var.bash"

PM_FILE="KaptainPM.yaml"

log "=== Load Project KaptainPM Docker Logins ==="

if [[ ! -f "${PM_FILE}" ]]; then
  log_error "KaptainPM.yaml not found in project root"
  exit 1
fi

if ! yq eval '.' "${PM_FILE}" > /dev/null 2>&1; then
  log_error "Invalid YAML syntax in ${PM_FILE}"
  exit 1
fi

# Extract registry login config as a single-line JSON string for
# docker-registry-logins. JSON is used (not YAML) because it collapses to one
# line, which makes it safe to pass as a single env var / string argument.
logins_json=$(yq -o=json -c '.spec.main.docker.logins // ""' "${PM_FILE}")
if [[ -n "${logins_json}" && "${logins_json}" != "null" && "${logins_json}" != '""' ]]; then
  output_var "DOCKER_REGISTRY_LOGINS" "${logins_json}" > /dev/null
  log "Field .spec.main.docker.logins exported as DOCKER_REGISTRY_LOGINS (JSON)"
else
  log "No registry logins configured in ${PM_FILE}"
fi

log "Done"
